{
  "name": "@isonia/types",
  "version": "0.8.0-alpha.3",
  "description": "Pure TypeScript shared domain types for IsoniaOS",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./activation/*": {
      "types": "./dist/activation/*.d.ts",
      "default": "./dist/activation/*.js"
    },
    "./base/*": {
      "types": "./dist/base/*.d.ts",
      "default": "./dist/base/*.js"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.ts",
      "default": "./dist/constants/*.js"
    },
    "./enums/*": {
      "types": "./dist/enums/*.d.ts",
      "default": "./dist/enums/*.js"
    },
    "./events/*": {
      "types": "./dist/events/*.d.ts",
      "default": "./dist/events/*.js"
    },
    "./finalization/*": {
      "types": "./dist/finalization/*.d.ts",
      "default": "./dist/finalization/*.js"
    },
    "./graph/*": {
      "types": "./dist/graph/*.d.ts",
      "default": "./dist/graph/*.js"
    },
    "./rest/*": {
      "types": "./dist/rest/*.d.ts",
      "default": "./dist/rest/*.js"
    },
    "./setup/*": {
      "types": "./dist/setup/*.d.ts",
      "default": "./dist/setup/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22"
  }
}
